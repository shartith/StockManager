#!/usr/bin/env node

const path = require('path');
const os = require('os');
const fs = require('fs');
const { spawn, execSync } = require('child_process');

const dataDir = process.env.STOCK_MANAGER_DATA || path.join(os.homedir(), '.stock-manager');
if (!fs.existsSync(dataDir)) {
  fs.mkdirSync(dataDir, { recursive: true });
}

const pidFile = path.join(dataDir, 'stock-manager.pid');
const logFile = path.join(dataDir, 'stock-manager.log');
const appRoot = path.resolve(__dirname, '..');
const pkg = require(path.join(appRoot, 'package.json'));
const port = process.env.PORT || 3000;

const command = process.argv[2];

// v4.13.0: 로컬 MLX 번들 제거. LLM은 외부 OpenAI 호환 서버를 사용하며,
// URL/모델/API 키는 Settings UI에서 설정한다. bin/ 에서 자동 기동/설치하지 않는다.
// 기존 venv(~/.stock-manager/venv)가 남아 있다면 수동으로 제거해도 된다.

// ── MLX venv 잔존 감지 및 제거 (v4.13.0~) ──
// v4.12.x 에서 bin/stock-manager 가 자동 생성하던 ~/.stock-manager/venv (mlx-lm 설치) 정리.
// Ollama는 이제 정식 지원 provider 이므로 자동 경고하지 않는다 — 필요 시 수동 uninstall.

function getOllamaDir() {
  return path.join(os.homedir(), '.ollama');
}

function hasOllamaBinary() {
  try {
    execSync('which ollama', { stdio: 'ignore' });
    return true;
  } catch {
    return false;
  }
}

function hasOllamaData() {
  return fs.existsSync(getOllamaDir());
}

function getMlxVenvDir() {
  return path.join(dataDir, 'venv');
}

function hasMlxVenv() {
  return fs.existsSync(path.join(getMlxVenvDir(), 'bin', 'mlx_lm.server'));
}

function detectMlxLeftovers() {
  if (!hasMlxVenv()) return;
  let sizeHint = '';
  try {
    const du = execSync(`du -sh "${getMlxVenvDir()}" 2>/dev/null | awk '{print $1}'`, { encoding: 'utf-8' }).trim();
    if (du) sizeHint = ` (~${du})`;
  } catch {}

  console.log('');
  console.log('  ┌─────────────────────────────────────────────────────────────┐');
  console.log('  │  v4.12.x MLX venv 잔존 감지                                 │');
  console.log('  ├─────────────────────────────────────────────────────────────┤');
  console.log('  │  v4.13.0부터 외부 LLM (Ollama/OpenAI 원격) 사용.            │');
  console.log(`  │  디스크 공간 회수를 위해 제거 권장${sizeHint}`);
  console.log('  │                                                             │');
  console.log('  │  자동 제거:  stock-manager --uninstall-mlx                  │');
  console.log('  └─────────────────────────────────────────────────────────────┘');
  console.log('');
}

function uninstallMlx() {
  const venv = getMlxVenvDir();
  if (!hasMlxVenv()) {
    console.log('  제거할 MLX venv 가 없습니다.');
    return;
  }
  console.log('');
  console.log(`  MLX venv 제거: ${venv}`);
  const readline = require('readline');
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  rl.question('  계속하시겠습니까? [y/N] ', (answer) => {
    rl.close();
    if (answer.trim().toLowerCase() !== 'y') { console.log('  취소됨'); return; }
    try {
      fs.rmSync(venv, { recursive: true, force: true });
      console.log('  MLX venv 제거 완료');
    } catch (e) {
      console.log(`  WARN: 삭제 실패 — ${e.message}`);
    }
  });
}

function uninstallOllama() {
  console.log('');
  console.log('  Ollama 완전 제거 (바이너리 + 모델 + 설정)');
  console.log('  --------------------');
  if (hasOllamaBinary()) console.log('  - ollama 바이너리 제거');
  if (hasOllamaData()) console.log(`  - ${getOllamaDir()} 제거 (모델 포함)`);
  console.log('');

  if (!hasOllamaBinary() && !hasOllamaData()) {
    console.log('  제거할 Ollama가 없습니다.');
    return;
  }

  // Confirmation prompt
  const readline = require('readline');
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  rl.question('  계속하시겠습니까? [y/N] ', (answer) => {
    rl.close();
    if (answer.trim().toLowerCase() !== 'y') {
      console.log('  취소됨');
      return;
    }

    // 1. 프로세스 종료
    try { execSync('pkill -x ollama 2>/dev/null || true'); } catch {}

    // 2. brew 서비스 중지 + uninstall
    try { execSync('brew services stop ollama 2>/dev/null || true'); } catch {}
    try {
      execSync('brew list ollama > /dev/null 2>&1');
      console.log('  brew uninstall ollama...');
      execSync('brew uninstall ollama', { stdio: 'inherit' });
    } catch {}

    // 3. ~/.ollama 제거
    if (hasOllamaData()) {
      console.log(`  ${getOllamaDir()} 삭제 중...`);
      try {
        fs.rmSync(getOllamaDir(), { recursive: true, force: true });
      } catch (e) {
        console.log(`  WARN: 삭제 실패 — ${e.message}`);
      }
    }

    console.log('  Ollama 제거 완료');
  });
}

function isRunning(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function getPid() {
  if (!fs.existsSync(pidFile)) return null;
  const pid = parseInt(fs.readFileSync(pidFile, 'utf-8').trim(), 10);
  if (isNaN(pid) || !isRunning(pid)) {
    fs.unlinkSync(pidFile);
    return null;
  }
  return pid;
}

function startDaemon() {
  const existing = getPid();
  if (existing) {
    console.log(`  Stock Manager is already running (PID: ${existing})`);
    console.log(`  http://localhost:${port}`);
    return;
  }

  detectMlxLeftovers();

  const out = fs.openSync(logFile, 'a');
  const err = fs.openSync(logFile, 'a');

  const child = spawn(process.execPath, [__filename, '_run'], {
    detached: true,
    stdio: ['ignore', out, err],
    env: { ...process.env, STOCK_MANAGER_DATA: dataDir, PORT: String(port) },
  });

  fs.writeFileSync(pidFile, String(child.pid));
  child.unref();

  console.log('');
  console.log(`  Stock Manager v${pkg.version} started`);
  console.log('  --------------------');
  console.log(`  PID:    ${child.pid}`);
  console.log(`  Data:   ${dataDir}`);
  console.log(`  Log:    ${logFile}`);
  console.log(`  Server: http://localhost:${port}`);
  console.log('');
}

function stopDaemon() {
  const pid = getPid();
  if (!pid) {
    console.log('  Stock Manager is not running');
    return;
  }

  try {
    process.kill(pid, 'SIGTERM');
    // Wait up to 5s for graceful shutdown
    for (let i = 0; i < 50; i++) {
      if (!isRunning(pid)) break;
      execSync('sleep 0.1');
    }
    if (isRunning(pid)) process.kill(pid, 'SIGKILL');
  } catch {}

  if (fs.existsSync(pidFile)) fs.unlinkSync(pidFile);
  console.log(`  Stock Manager stopped (PID: ${pid})`);
}

function showStatus() {
  const pid = getPid();
  if (pid) {
    console.log(`  Stock Manager is running (PID: ${pid})`);
    console.log(`  http://localhost:${port}`);
  } else {
    console.log('  Stock Manager is not running');
  }
}

function runServer() {
  process.env.STOCK_MANAGER_DATA = dataDir;
  process.env.STOCK_MANAGER_CLIENT = path.join(appRoot, 'client', 'dist');
  process.env.PORT = String(port);

  console.log('');
  console.log(`  Stock Manager v${pkg.version}`);
  console.log('  --------------------');
  console.log(`  Data:   ${dataDir}`);
  console.log(`  Server: http://localhost:${port}`);
  console.log('');

  require(path.join(appRoot, 'server', 'dist', 'index.js'));
}

// Command routing
switch (command) {
  case '--uninstall-ollama':
  case 'uninstall-ollama':
    uninstallOllama();
    break;
  case '--uninstall-mlx':
  case 'uninstall-mlx':
    uninstallMlx();
    break;
  case 'start':
    startDaemon();
    break;
  case 'stop':
    stopDaemon();
    break;
  case 'restart':
    stopDaemon();
    startDaemon();
    break;
  case 'status':
    showStatus();
    break;
  case 'log':
  case 'logs':
    if (fs.existsSync(logFile)) {
      const lines = process.argv[3] ? parseInt(process.argv[3], 10) : 50;
      try {
        const output = execSync(`tail -n ${lines} "${logFile}"`, { encoding: 'utf-8' });
        process.stdout.write(output);
      } catch {
        console.log(fs.readFileSync(logFile, 'utf-8').split('\n').slice(-lines).join('\n'));
      }
    } else {
      console.log('  No log file found');
    }
    break;
  case 'export-strategy':
  case 'import-strategy':
  case 'export-lora':
  case 'backup':
  case 'restore': {
    process.env.STOCK_MANAGER_DATA = dataDir;
    const dbModule = require(path.join(appRoot, 'server', 'dist', 'db.js'));
    dbModule.initializeDB().then(() => {
      const ei = require(path.join(appRoot, 'server', 'dist', 'services', 'exportImport.js'));
      let result;
      if (command === 'export-strategy') {
        result = ei.exportStrategy();
        console.log('\n' + result.summary + '\n');
      } else if (command === 'import-strategy') {
        const file = process.argv[3];
        if (!file) { console.log('  Usage: stock-manager import-strategy <file.json>'); return; }
        result = ei.importStrategy(path.resolve(file));
        console.log('\n' + (result.success ? result.message : '  ERROR: ' + result.message) + '\n');
      } else if (command === 'backup') {
        result = ei.exportFullConfig();
        console.log('\n' + result.message + '\n');
      } else if (command === 'restore') {
        const file = process.argv[3];
        if (!file) { console.log('  Usage: stock-manager restore <backup-file.json>'); return; }
        result = ei.importFullConfig(path.resolve(file));
        console.log('\n' + (result.success ? result.message : '  ERROR: ' + result.message) + '\n');
      } else {
        result = ei.generateLoraDataset();
        console.log('\n' + result.message + '\n');
      }
    }).catch((err) => { console.error('DB 초기화 실패:', err.message); });
    break;
  }
  case 'sync': {
    process.env.STOCK_MANAGER_DATA = dataDir;
    const dbModule = require(path.join(appRoot, 'server', 'dist', 'db.js'));
    dbModule.initializeDB().then(async () => {
      const { runNasSync, getSyncStatus } = require(path.join(appRoot, 'server', 'dist', 'services', 'nasSync.js'));

      if (process.argv[3] === '--status') {
        const status = getSyncStatus();
        console.log('\n  NAS 동기화 상태');
        console.log('  --------------------');
        console.log(`  활성화: ${status.enabled ? '예' : '아니오'}`);
        console.log(`  NAS 경로: ${status.nasPath || '(미설정)'}`);
        console.log(`  기기 ID: ${status.deviceId}`);
        if (status.lastSync) {
          console.log(`  마지막 동기화: ${status.lastSync.lastSyncAt}`);
          console.log(`  테이블: ${status.lastSync.tablesExported}개, 레코드: ${status.lastSync.totalRecords}건`);
        } else {
          console.log('  마지막 동기화: 없음');
        }
        console.log('');
        return;
      }

      const includeSecrets = process.argv.includes('--backup') || process.argv.includes('--include-secrets');
      console.log(includeSecrets ? '\n  로컬 백업 실행 중 (API 키 포함)...' : '\n  NAS 동기화 실행 중 (API 키 마스킹)...');
      const result = await runNasSync({ includeSecrets });
      console.log(`  ${result.success ? '✓' : '✗'} ${result.message}`);
      if (result.syncPath) console.log(`  경로: ${result.syncPath}`);
      console.log('');
    }).catch((err) => { console.error('DB 초기화 실패:', err.message); });
    break;
  }
  case 'run':
  case '_run':
    runServer();
    break;
  case undefined:
    startDaemon();
    break;
  default:
    console.log(`
  Stock Manager v${pkg.version}

  Usage:
    stock-manager              Start as background daemon
    stock-manager start        Start as background daemon
    stock-manager run          Run in foreground
    stock-manager stop         Stop the daemon
    stock-manager restart      Restart the daemon
    stock-manager status       Show running status
    stock-manager logs [n]     Show last n log lines (default: 50)

  Maintenance:
    stock-manager --uninstall-mlx      Remove legacy MLX venv (~/.stock-manager/venv)
    stock-manager --uninstall-ollama   Remove local Ollama binary + models (~/.ollama)

  LLM:
    v4.13.0부터 외부 OpenAI 호환 LLM 서버를 사용합니다.
    URL/모델/API 키는 웹 UI의 Settings 화면에서 설정하세요.
    예: https://ai.unids.kr/v1, http://localhost:11434/v1 (Ollama), https://api.openai.com/v1

  Strategy:
    stock-manager export-strategy          Export strategy (no credentials)
    stock-manager import-strategy <file>   Import strategy from JSON
    stock-manager export-lora              Export LoRA training dataset

  Backup:
    stock-manager backup                   Full config backup (API keys included)
    stock-manager restore <file>           Restore full config from backup

  NAS Sync / Backup:
    stock-manager sync                     NAS sync (API keys masked)
    stock-manager sync --backup            Local backup (API keys INCLUDED, for restore)
    stock-manager sync --status            Show NAS sync status
`);
}
