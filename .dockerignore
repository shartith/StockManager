data
**/*.db
**/*.db-shm
**/*.db-wal
**/*.db.bak*
data/settings.json
stock-data
datasets

# Logs
*.log
**/*.log

# Tests / e2e artifacts
test-results
playwright-report
e2e

# Local env files (secrets)
.env
.env.*
!.env.example

# OS / misc
Thumbs.db

# Docs not needed in image
docs
*.md
!README.md

# Docker meta
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
